# NeuralSwarm 环境变量
# 复制此文件为 .env 并修改

# ── 应用 ────────────────────────
NS_APP_NAME=neuralswarm
NS_HOST=0.0.0.0
NS_PORT=8000
NS_DEBUG=false

# ── 数据库 ──────────────────────
NS_DB_USER=neuralswarm
NS_DB_PASSWORD=neuralswarm
NS_DB_NAME=neuralswarm
NS_DB_PORT=5432
NS_DATABASE_URL=postgresql+asyncpg://neuralswarm:neuralswarm@localhost:5432/neuralswarm

# ── Redis ───────────────────────
NS_REDIS_PORT=6380
NS_REDIS_PASSWORD=
NS_REDIS_URL=redis://localhost:6380/0

# ── LLM 网关 ────────────────────
NS_LLM_GATEWAY_URL=http://localhost:3000
NS_LLM_GATEWAY_TIMEOUT=30

# ── Docker 开发工具 ─────────────
NS_ADMINER_PORT=8080
NS_REDIS_COMMANDER_PORT=8081

# ── Qdrant 向量数据库 ───────────
NS_QDRANT_URL=http://localhost:6333
NS_QDRANT_COLLECTION=neuralswarm
NS_QDRANT_PORT=6333
NS_QDRANT_GRPC_PORT=6334

# ── MCP 协议 ────────────────────
NS_MCP_WEBSOCKET_PORT=8765
NS_MCP_TIMEOUT=30

# ── 记忆系统 ────────────────────
NS_L1_TTL_HOURS=24
NS_L2_EMBEDDING_MODEL=all-MiniLM-L6-v2
