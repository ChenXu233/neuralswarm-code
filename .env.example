# NeuralSwarm 环境变量
# 复制此文件为 .env 并修改

# ── 应用 ────────────────────────
NS_APP_NAME=neuralswarm
NS_HOST=0.0.0.0
NS_PORT=8000
NS_DEBUG=false

# ── 数据库 ──────────────────────
NS_DB_USER=neuralswarm
NS_DB_PASSWORD=neuralswarm
NS_DB_NAME=neuralswarm
NS_DB_PORT=5432
NS_DATABASE_URL=postgresql+asyncpg://${NS_DB_USER}:${NS_DB_PASSWORD}@localhost:${NS_DB_PORT}/${NS_DB_NAME}

# ── Redis ───────────────────────
NS_REDIS_PORT=6379
NS_REDIS_PASSWORD=
NS_REDIS_URL=redis://localhost:${NS_REDIS_PORT}/0

# ── LLM 网关 ────────────────────
NS_LLM_GATEWAY_URL=http://localhost:3000
NS_LLM_GATEWAY_TIMEOUT=30

# ── Docker 开发工具 ─────────────
NS_ADMINER_PORT=8080
NS_REDIS_COMMANDER_PORT=8081
